#!/bin/sh
# Auto-bump patch version when link_ctl.py is part of the commit.
# prepare-commit-msg then injects the new version into the commit message.
# Install: git config core.hooksPath .githooks
if git diff --cached --name-only | grep -q "^link_ctl\.py$"; then
    python3 "$(git rev-parse --show-toplevel)/scripts/bump_version.py"
fi

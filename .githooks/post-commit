#!/bin/sh
# Auto-tag when link_ctl.py was part of the commit.
# Reads the version from pyproject.toml and creates a vX.Y.Z tag.

if git diff HEAD~1 HEAD --name-only 2>/dev/null | grep -q "^link_ctl\.py$"; then
    VERSION=$(grep '^version = ' pyproject.toml | sed 's/version = "\(.*\)"/\1/')
    TAG="v${VERSION}"
    if git tag "$TAG" 2>/dev/null; then
        echo "Tagged ${TAG}"
        git push origin "$TAG"
    fi
fi
